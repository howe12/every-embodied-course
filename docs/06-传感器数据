## 3. 深度相机数据处理

本节将介绍深度相机数据的常用处理方法，包括深度图像读取、点云转换和可视化。

### 3.1 订阅深度图像

```python
# depth_image_subscriber.py - 订阅深度图像
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image
import numpy as np

class DepthImageSubscriber(Node):
    def __init__(self):
        super().__init__('depth_image_subscriber')
        self.subscription = self.create_subscription(
            Image,
            '/camera/depth/image_raw',
            self.depth_callback,
            10
        )
        self.get_logger().info('Depth image subscriber started')
        
    def depth_callback(self, msg):
        # 将ROS2图像消息转换为numpy数组
        # 假设使用16UC1格式（毫米）
        if msg.encoding == '16UC1':
            depth = np.frombuffer(msg.data, dtype=np.uint16)
            depth = depth.reshape((msg.height, msg.width))
            depth_meters = depth.astype(np.float32) / 1000.0  # 转换为米
        elif msg.encoding == '32FC1':
            depth = np.frombuffer(msg.data, dtype=np.float32)
            depth_meters = depth.reshape((msg.height, msg.width))
        else:
            self.get_logger().warn(f'Unsupported encoding: {msg.encoding}')
            return
            
        # 计算深度统计信息
        valid_depth = depth_meters[depth_meters > 0]
        if len(valid_depth) > 0:
            min_depth = np.min(valid_depth)
            max_depth = np.max(valid_depth)
            avg_depth = np.mean(valid_depth)
            
            self.get_logger().info(
                f'Depth range: {min_depth:.2f}m - {max_depth:.2f}m, '
                f'avg: {avg_depth:.2f}m'
            )

def main(args=None):
    rclpy.init(args=args)
    node = DepthImageSubscriber()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
```

### 3.2 订阅点云数据

```python
# point_cloud_subscriber.py - 订阅点云数据
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import PointCloud2
import numpy as np

class PointCloudSubscriber(Node):
    def __init__(self):
        super().__init__('point_cloud_subscriber')
        self.subscription = self.create_subscription(
            PointCloud2,
            '/camera/depth/points',
            self.cloud_callback,
            10
        )
        self.get_logger().info('Point cloud subscriber started')
        
    def cloud_callback(self, msg):
        # 将PointCloud2转换为numpy数组
        points = self.pointcloud2_to_array(msg)
        
        if len(points) > 0:
            # 计算点云统计信息
            x = points['x']
            y = points['y']
            z = points['z']
            
            # 过滤有效点（z > 0 表示在相机前方）
            valid = z > 0
            if np.any(valid):
                min_z = np.min(z[valid])
                max_z = np.max(z[valid])
                
                self.get_logger().info(
                    f'Points: {len(points)}, '
                    f'Z range: {min_z:.2f}m - {max_z:.2f}m'
                )
                
    def pointcloud2_to_array(self, cloud_msg):
        """将PointCloud2消息转换为numpy结构化数组"""
        # 解析fields
        dtype_list = []
        for field in cloud_msg.fields:
            if field.datatype == 7:  # float32
                dtype = np.float32
            elif field.datatype == 8:  # float64
                dtype = np.float64
            elif field.datatype == 4:  # uint16
                dtype = np.uint16
            else:
                continue
            dtype_list.append((field.name, dtype))
            
        # 解析点云数据
        points = np.frombuffer(cloud_msg.data, dtype=dtype_list)
        return points

def main(args=None):
    rclpy.init(args=args)
    node = PointCloudSubscriber()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
```

### 3.3 深度图像转点云

```python
# depth_to_pointcloud.py - 将深度图像转换为点云
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image, CameraInfo, PointCloud2
from geometry_msgs.msg import Point32
from sensor_msgs import point_cloud2
import numpy as np

class DepthToPointCloud(Node):
    def __init__(self):
        super().__init__('depth_to_pointcloud')
        
        # 订阅深度图像和相机内参
        self.depth_sub = self.create_subscription(
            Image, '/camera/depth/image_raw', self.depth_callback, 10)
        self.info_sub = self.create_subscription(
            CameraInfo, '/camera/depth/camera_info', self.info_callback, 10)
            
        # 发布点云
        self.publisher = self.create_publisher(
            PointCloud2, '/depth/points', 10)
            
        self.camera_info = None
        self.get_logger().info('Depth to point cloud converter started')
        
    def info_callback(self, msg):
        self.camera_info = msg
        
    def depth_callback(self, msg):
        if self.camera_info is None:
            return
            
        # 提取相机内参
        K = self.camera_info.k
        fx = K[0]
        fy = K[4]
        cx = K[2]
        cy = K[5]
        
        # 解析深度图像
        if msg.encoding == '16UC1':
            depth = np.frombuffer(msg.data, dtype=np.uint16)
            depth = depth.reshape((msg.height, msg.width)).astype(np.float32) / 1000.0
        else:
            return
            
        # 生成点云
        points = []
        for v in range(msg.height):
            for u in range(msg.width):
                Z = depth[v, u]
                if Z > 0 and Z < 10.0:  # 过滤无效和过远的点
                    X = (u - cx) * Z / fx
                    Y = (v - cy) * Z / fy
                    points.append([X, Y, Z])
                    
        # 创建PointCloud2消息
        header = msg.header
        pc2 = point_cloud2.create_cloud(header, ['x', 'y', 'z'], points)
        
        self.publisher.publish(pc2)

def main(args=None):
    rclpy.init(args=args)
    node = DepthToPointCloud()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
```


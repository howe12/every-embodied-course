## 5. 实战：基于深度相机的3D物体检测

本节我们将实现一个基于深度相机的**3D物体检测系统**，结合RGB图像的目标检测和深度信息来获取物体的三维位置。

### 5.1 系统概述

该系统使用YOLOv8进行2D目标检测，结合深度图像获取每个检测框内物体的三维位置信息。

```
RGB图像 ──▶ YOLOv8检测 ──┐
                        ├──▶ 3D边界框 ──▶ 3D目标跟踪
深度图像 ────────────────┘
```

### 5.2 3D物体检测节点

```python
# 3d_object_detection.py - 3D物体检测
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image, CameraInfo
from vision_msgs.msg import Detection2DArray, Detection3DArray
from geometry_msgs.msg import Pose, Vector3
import numpy as np

# 假设使用ultralytics的YOLOv8
try:
    from ultralytics import YOLO
    YOLO_AVAILABLE = True
except ImportError:
    YOLO_AVAILABLE = False
    print("Warning: ultralytics not installed. Install with: pip install ultralytics")

class ObjectDetection3D(Node):
    def __init__(self):
        super().__init__('object_detection_3d')
        
        # 订阅RGB图像和深度图像
        self.rgb_sub = self.create_subscription(
            Image, '/camera/color/image_raw', self.rgb_callback, 10)
        self.depth_sub = self.create_subscription(
            Image, '/camera/depth/image_raw', self.depth_callback, 10)
        self.info_sub = self.create_subscription(
            CameraInfo, '/camera/depth/camera_info', self.info_callback, 10)
            
        # 发布3D检测结果
        self.detection_pub = self.create_publisher(
            Detection3DArray, '/detections_3d', 10)
            
        # 相机内参
        self.camera_info = None
        self.latest_depth = None
        
        # 加载YOLOv8模型（如果可用）
        if YOLO_AVAILABLE:
            self.model = YOLO('yolov8n.pt')  # 使用nano版本以提高速度
            self.get_logger().info('YOLOv8 model loaded')
        else:
            self.model = None
            self.get_logger().warn('YOLOv8 not available, using simple detection')
            
        self.get_logger().info('3D Object detection node started')
        
    def info_callback(self, msg):
        self.camera_info = msg
        
    def rgb_callback(self, msg):
        if self.latest_depth is None or self.camera_info is None:
            return
            
        # 进行2D目标检测
        if self.model:
            results = self.model(self.image_msg_to_numpy(msg))
            detections_3d = self.process_detections(results, msg.header)
        else:
            detections_3d = Detection3DArray()
            detections_3d.header = msg.header
            
        self.detection_pub.publish(detections_3d)
        
    def depth_callback(self, msg):
        # 更新最新深度图像
        self.latest_depth = msg
        
    def process_detections(self, results, header):
        """处理检测结果，计算3D位置"""
        detections = Detection3DArray()
        detections.header = header
        
        # 提取相机内参
        K = self.camera_info.k
        fx, fy = K[0], K[4]
        cx, cy = K[2], K[5]
        
        for result in results:
            boxes = result.boxes
            for box in boxes:
                # 获取2D边界框
                x1, y1, x2, y2 = box.xyxy[0].cpu().numpy()
                conf = float(box.conf[0])
                cls_id = int(box.cls[0])
                
                # 计算边界框中心在图像上的坐标
                u = int((x1 + x2) / 2)
                v = int((y1 + y2) / 2)
                
                # 获取该位置的深度值
                if u < self.latest_depth.width and v < self.latest_depth.height:
                    # 16UC1格式：毫米转米
                    depth_mm = self.latest_depth.data[v * self.latest_depth.width + u]
                    Z = depth_mm / 1000.0  # 转换为米
                    
                    if Z > 0 and Z < 10:  # 有效深度范围
                        # 计算3D坐标
                        X = (u - cx) * Z / fx
                        Y = (v - cy) * Z / fy
                        
                        # 创建3D检测结果
                        detection = Detection3D()
                        detection.bbox.center.position.x = X
                        detection.bbox.center.position.y = Y
                        detection.bbox.center.position.z = Z
                        
                        # 边界框尺寸（使用2D框的尺寸作为近似）
                        detection.bbox.size.x = (x2 - x1) * Z / fx
                        detection.bbox.size.y = (y2 - y1) * Z / fy
                        detection.bbox.size.z = 0.5  # 假设物体高度
                        
                        detection.results.append(Detection3D.Result())
                        detection.results[-1].hypothesis.class_id = str(cls_id)
                        detection.results[-1].hypothesis.score = conf
                        
                        detections.detections.append(detection)
                        
        return detections
        
    def image_msg_to_numpy(self, msg):

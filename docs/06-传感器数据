## 4. 实战：基于深度相机的避障系统

本节我们将实现一个基于深度相机的**避障系统**，通过深度图像检测前方的障碍物并生成避障策略。

### 4.1 系统架构

```
┌─────────────────┐
│  深度相机       │ ──▶ /camera/depth/image_raw
│  (RealSense)   │ ──▶ /camera/depth/camera_info
└─────────────────┘
        │
        ▼
┌─────────────────┐
│  障碍物检测节点  │ ◀── 订阅深度图像
│ (Obstacle Node) │ ──▶ /obstacle/detections
└─────────────────┘
        │
        ▼
┌─────────────────┐
│  避障决策节点   │ ◀── 订阅障碍物检测
│ (Avoid Node)    │ ──▶ /cmd_vel (速度命令)
└─────────────────┘
```

### 4.2 障碍物检测节点

```python
# obstacle_detection.py - 基于深度图像的障碍物检测
import rclpy
from rclpy.node import Node
from sensor_msgs.msg import Image
from vision_msgs.msg import Detection2DArray, BoundingBox2D
from geometry_msgs.msg import Pose2D
import numpy as np

class ObstacleDetection(Node):
    def __init__(self):
        super().__init__('obstacle_detection')
        
        # 订阅深度图像
        self.depth_sub = self.create_subscription(
            Image,
            '/camera/depth/image_raw',
            self.depth_callback,
            10
        )
        
        # 发布障碍物检测结果
        self.detection_pub = self.create_publisher(
            Detection2DArray,
            '/obstacle/detections',
            10
        )
        
        # 相机参数（需要根据实际相机标定）
        self.fx = 615.0
        self.fy = 615.0
        self.cx = 320.0
        self.cy = 240.0
        
        # 障碍物距离阈值（米）
        self.min_distance = 0.3
        self.max_distance = 3.0
        
        self.get_logger().info('Obstacle detection node started')
        
    def depth_callback(self, msg):
        # 解析深度图像
        depth = np.frombuffer(msg.data, dtype=np.uint16)
        depth = depth.reshape((msg.height, msg.width)).astype(np.float32) / 1000.0
        
        # 障碍物检测
        detections = self.detect_obstacles(depth, msg.header)
        
        # 发布检测结果
        self.detection_pub.publish(detections)
        
    def detect_obstacles(self, depth, header):
        """检测障碍物并计算位置"""
        detections = Detection2DArray()
        detections.header = header
        
        # 将深度图像划分为网格
        h, w = depth.shape
        grid_size = 8  # 8x8 网格
        cell_h = h // grid_size
        cell_w = w // grid_size
        
        for i in range(grid_size):
            for j in range(grid_size):
                # 提取网格区域
                y_start = i * cell_h
                y_end = (i + 1) * cell_h
                x_start = j * cell_w
                x_end = (j + 1) * cell_w
                
                cell = depth[y_start:y_end, x_start:x_end]
                
                # 计算该区域的最小深度
                valid_depth = cell[(cell > self.min_distance) & (cell < self.max_distance)]
                
                if len(valid_depth) > 0:
                    min_dist = np.min(valid_depth)
                    
                    # 如果距离小于阈值，标记为障碍物
                    if min_dist < 1.0:  # 1米内视为危险
                        # 计算障碍物在相机坐标系下的位置
                        center_u = (x_start + x_end) // 2
                        center_v = (y_start + y_end) // 2
                        
                        Z = min_dist
                        X = (center_u - self.cx) * Z / self.fx
                        Y = (center_v - self.cy) * Z / self.fy
                        
                        # 创建检测结果
                        detection = Detection2DArray()
                        bbox = BoundingBox2D()
                        bbox.center.position.x = float(center_u)
                        bbox.center.position.y = float(center_v)
                        bbox.size_x = float(cell_w)
                        bbox.size_y = float(cell_h)
                        
                        # 距离信息存储在header的frame_id中
                        detection.detections.append(bbox)
                        
        return detections

def main(args=None):
    rclpy.init(args=args)
    node = ObstacleDetection()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
```

### 4.3 避障决策节点

```python
# obstacle_avoidance.py - 避障决策节点
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist
from sensor_msgs.msg import Image
import numpy as np

class ObstacleAvoidance(Node):
    def __init__(self):
        super().__init__('obstacle_avoidance')
        
        # 订阅深度图像（直接使用原始数据做决策）
        self.depth_sub = self.create_subscription(
            Image,
            '/camera/depth/image_raw',
            self.depth_callback,
            10
        )
        
        # 发布速度命令
        self.cmd_pub = self.create_publisher(
            Twist,
            '/cmd_vel',
            10
        )
        
        # 速度参数
        self.max_linear_speed = 0.3  # m/s
        self.max_angular_speed = 0.5  # rad/s
        
        # 停止距离阈值
        self.stop_distance = 0.4  # 米
        self.warning_distance = 0.8  # 米
        
        self.get_logger().info('Obstacle avoidance node started')
        
    def depth_callback(self, msg):
        # 解析深度图像
        depth = np.frombuffer(msg.data, dtype=np.uint16)
        depth = depth.reshape((msg.height, msg.width)).astype(np.float32) / 1000.0
        
        # 获取图像中心区域的深度值（机器人正前方）
        h, w = depth.shape
        center_region = depth[h//4:3*h//4, w//4:3*w//4]
        
        # 计算前方最小距离
        valid_depth = center_region[center_region > 0.1]
        min_distance = np.min(valid_depth) if len(valid_depth) > 0 else float('inf')
        
        # 生成速度命令
        cmd = Twist()
        
        if min_distance < self.stop_distance:
            # 距离太近，停止
            cmd.linear.x = 0.0
            cmd.angular.z = 0.0
            self.get_logger().warn(f'Stop! Obstacle at {min_distance:.2f}m')
            
        elif min_distance < self.warning_distance:
            # 距离较近，减速并转向
            speed_factor = (min_distance - self.stop_distance) / (self.warning_distance - self.stop_distance)
            cmd.linear.x = self.max_linear_speed * speed_factor * 0.3
            # 简单的避障策略：向左侧转向
            cmd.angular.z = self.max_angular_speed * 0.5
            self.get_logger().info(f'Slow down and turn! Distance: {min_distance:.2f}m')
            
        else:
            # 正常前进
            cmd.linear.x = self.max_linear_speed
            cmd.angular.z = 0.0
            
        self.cmd_pub.publish(cmd)

def main(args=None):
    rclpy.init(args=args)
    node = ObstacleAvoidance()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
```

